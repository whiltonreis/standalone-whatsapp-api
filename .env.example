WHATSAPP_API_KEY=defina-uma-chave-forte-aqui
WHATSAPP_API_HOST=0.0.0.0
WHATSAPP_API_PORT=3000
WHATSAPP_CORS_ORIGINS=
WHATSAPP_DISABLE_AUTH=false
WHATSAPP_BODY_LIMIT=256kb

WHATSAPP_COUNTRY_CODE=55
WHATSAPP_ENABLE_NINE_DIGIT_FALLBACK=true
WHATSAPP_MAX_MESSAGE_LENGTH=4096
WHATSAPP_LOG_MESSAGE_CONTENT=false
WHATSAPP_LOG_RETENTION_DAYS=15
WHATSAPP_DEV_LOG_RETENTION_DAYS=7
# WHATSAPP_DISABLE_LOG_CLEANUP=false

# Regra segura para Brasil:
# - sempre tenta primeiro exatamente o numero recebido
# - em numero com 9, o formato sem 9 entra apenas como fallback para compatibilidade
# - em numero de 8 digitos locais, so adiciona o 9 como fallback se o inicio nao parecer fixo (2 a 5)
# - para reduzir bloqueios, prefira validar no endpoint /resolve-number e gravar o numero canonico antes de enviar

# Se deixar em branco, a API tenta reaproveitar auth/logs/cache legados.
# Para um runtime isolado, descomente e ajuste:
# WHATSAPP_AUTH_DIR=runtime/auth
# WHATSAPP_LOG_DIR=runtime/logs
# WHATSAPP_NUMBER_CACHE_FILE=runtime/cache/numero_cache.json

WHATSAPP_RECONNECT_BASE_DELAY_MS=3000
WHATSAPP_RECONNECT_MAX_DELAY_MS=30000
